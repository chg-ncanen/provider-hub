##############################################################################
# PDE Ops Toolkit - Environment Configuration
# 
# This file defines secrets and runtime overrides for the toolkit.
# Copy this to .env and fill in your credentials.
# 
# CONFIGURATION STRATEGY:
# - Non-secrets (Cloud ID, profiles, filters): go in app_config.json
# - Secrets (API tokens, passwords): go in .env
# - app_config.json is version-controlled; .env is .gitignored
##############################################################################

##############################################################################
# REQUIRED: Atlassian JSM Credentials (for all operations)
##############################################################################

# Your Atlassian Cloud email address
# Used for authentication with JSM API
# Example: your-name@company.com
ATLASSIAN_EMAIL=your-email@example.com

# Atlassian API Token (NOT your password)
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
# Click "Create API token" and copy the full token here
# KEEP THIS SECRET - do not commit to version control
ATLASSIAN_API_TOKEN=your-atlassian-api-token


##############################################################################
# OPTIONAL: Email Integration (for alert notifications and exports)
# 
# Only needed if:
# - Sending alert summaries via email
# - Reading alerts from email inboxes
# 
# If not using email features, you can leave these commented out.
##############################################################################

# Email account username (typically your email address)
# Example: your-email@gmail.com
# EMAIL_USERNAME=your-email@gmail.com

# Email account password or app-specific password
# 
# IMPORTANT: Security varies by provider:
# - Gmail: Use an "App Password" (not your account password)
#   https://support.google.com/accounts/answer/185833
# - Outlook: Use your account password or app password
# - Other: Check your email provider's security docs
# 
# EMAIL_PASSWORD=your-app-password

# IMAP server for receiving emails
# Default for Gmail: imap.gmail.com
# Default for Outlook: outlook.office365.com
# Uncomment and change if using a different provider
# EMAIL_IMAP_HOST=imap.gmail.com

# IMAP port (usually 993 for SSL/TLS)
# EMAIL_IMAP_PORT=993

# SMTP server for sending emails
# Default for Gmail: smtp.gmail.com
# Default for Outlook: smtp-mail.outlook.com
# Uncomment and change if using a different provider
# EMAIL_SMTP_HOST=smtp.gmail.com

# SMTP port (usually 587 for TLS, 465 for SSL)
# EMAIL_SMTP_PORT=587


##############################################################################
# VERIFICATION
##############################################################################

# After filling in credentials, test by starting the MCP server directly and
# confirming it doesn't exit immediately with a credentials/import error:
#   python3 app.py
# (it sits waiting on stdio for an MCP client — Ctrl+C to stop)

